# paper-curation API 키 템플릿
# 이 파일을 .env 로 복사한 뒤 값을 채우세요:  cp .env.sample .env
# .env 는 gitignore 로 커밋에서 제외되며, 셸에 이미 설정된 환경변수가 .env 값보다 우선합니다.

# 필수 — 논문 리뷰·분류·타임라인 생성 (Claude)
# 발급: https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=

# 필수 — Deep Research 검색 인덱스 빌드 (text-embedding-3-small)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 선택 — 그림(figure) 검증 (Gemini). 없으면 해당 단계 스킵
# 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# 선택 — Zotero API 키. config.json 의 zotero.api_key 가 우선이며 보통 그쪽에 저장
# 발급: https://www.zotero.org/settings/keys
#ZOTERO_API_KEY=

# 선택 — Cloudflare 배포용 (--mode deploy 사용 시에만 필요)
#CLOUDFLARE_API_TOKEN=
#CLOUDFLARE_ACCOUNT_ID=
